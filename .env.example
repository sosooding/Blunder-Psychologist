# Copy to .env (cp .env.example .env  /  Copy-Item .env.example .env) before `docker compose up`.

# LLM provider for the agent layer (used from Phase 4 onward): gemini | ollama
LLM_PROVIDER=ollama

# Database (host "postgres" is the compose service name; use localhost for local runs)
DATABASE_URL=postgresql+psycopg2://blunder:blunder@postgres:5432/blunder

# Lichess API token (used from Phase 3) — https://lichess.org/account/oauth/token
LICHESS_TOKEN=lip_your_token_here

# Provider credentials (wired up in later phases)
GEMINI_API_KEY=your_gemini_api_key_here

# Worker tuning
WORKER_POLL_INTERVAL=1.0
WORKER_MAX_ATTEMPTS=3
